PORT=3000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gly_vtu

JWT_SECRET=change_this_secret
JWT_ADMIN_SECRET=change_this_admin_secret
JWT_ACCESS_TTL=15m
JWT_ACCESS_COOKIE_MINUTES=15
JWT_REFRESH_DAYS=14
COOKIE_REFRESH=true
COOKIE_ENC_SECRET=change_this_cookie_secret
COOKIE_DOMAIN=
AUTH_COOKIE_NAME=auth_token
ADMIN_AUTH_COOKIE_NAME=admin_auth_token

# CORS allowlist (comma separated). Recommended to set explicitly in production.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Trust proxy hops (set to 1 if behind a reverse proxy like Nginx)
TRUST_PROXY=0

# SMTP for emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@glyvtu.ng
EMAIL_LOGO_URL=
BRAND_URL=
SUPPORT_URL=
PRIVACY_URL=
TERMS_URL=

OTP_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
PIN_MAX_ATTEMPTS=5
PIN_LOCK_MINUTES=15
LOGIN_LOCK_MAX=5
LOGIN_LOCK_MINUTES=15
LOGIN_LOCK_WINDOW_MINUTES=15
SECURITY_QUESTION_REQUIRE_PIN_CHANGE=true
SECURITY_QUESTION_REQUIRE_DEVICE_VERIFY=true
SECURITY_QUESTION_REQUIRE_PASSWORD_RESET=true
SECURITY_QUESTION_TRANSFER_LIMIT=50000

RATE_LIMIT_GLOBAL_MAX=600
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_ADMIN_AUTH_MAX=20
RATE_LIMIT_OTP_MAX=10
RATE_LIMIT_WEBHOOK_MAX=120
REDIS_URL=
IDEMPOTENCY_KEY_TTL_HOURS=24

BANKS_CACHE_TTL_MINUTES=1440
BANKS_REFRESH_INTERVAL_MS=21600000
WS_TOKEN_MAX_AGE_MINUTES=10
TOTP_ISSUER=GLY-VTU
TOTP_WINDOW=2

# VTpass (Bills)
VTPASS_BASE_URL=https://sandbox.vtpass.com
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_SECRET_KEY=
VTPASS_ENV=sandbox
VTPASS_WEBHOOK_SECRET=
VTPASS_WEBHOOK_IPS=

# Flutterwave (Virtual Accounts / Cards)
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_BASE_URL=https://api.flutterwave.com
FLW_WEBHOOK_HASH=

# KYC Provider
# Set KYC_PROVIDER=mock for local testing
KYC_PROVIDER=mock
KYC_PROVIDER_BASE_URL=
KYC_PROVIDER_BVN_PATH=/bvn
KYC_PROVIDER_NIN_PATH=/nin
KYC_PROVIDER_AUTH_HEADER=Authorization
KYC_PROVIDER_AUTH_TYPE=Bearer
KYC_PROVIDER_TOKEN=
KYC_PROVIDER_TIMEOUT_MS=10000
KYC_POST_VERIFY_WEBHOOK_URL=
KYC_POST_VERIFY_WEBHOOK_TOKEN=

# KYC Limits
KYC_L1_DAILY_LIMIT=50000
KYC_L1_MONTHLY_LIMIT=200000
KYC_L2_DAILY_LIMIT=500000
KYC_L2_MONTHLY_LIMIT=2000000
KYC_L3_DAILY_LIMIT=5000000
KYC_L3_MONTHLY_LIMIT=20000000

# Optional per-transaction-type overrides
# KYC_L1_DAILY_LIMIT_SEND=
# KYC_L1_DAILY_LIMIT_BILL=
# KYC_L1_DAILY_LIMIT_TOPUP=
# KYC_L1_MONTHLY_LIMIT_SEND=
# KYC_L1_MONTHLY_LIMIT_BILL=
# KYC_L1_MONTHLY_LIMIT_TOPUP=
# KYC_L2_DAILY_LIMIT_SEND=
# KYC_L2_DAILY_LIMIT_BILL=
# KYC_L2_DAILY_LIMIT_TOPUP=
# KYC_L2_MONTHLY_LIMIT_SEND=
# KYC_L2_MONTHLY_LIMIT_BILL=
# KYC_L2_MONTHLY_LIMIT_TOPUP=
# KYC_L3_DAILY_LIMIT_SEND=
# KYC_L3_DAILY_LIMIT_BILL=
# KYC_L3_DAILY_LIMIT_TOPUP=
# KYC_L3_MONTHLY_LIMIT_SEND=
# KYC_L3_MONTHLY_LIMIT_BILL=
# KYC_L3_MONTHLY_LIMIT_TOPUP=

FLW_EVENTS_RETENTION_DAYS=90
VTPASS_EVENTS_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=365
SECURITY_EVENT_RETENTION_DAYS=365
ADMIN_ADJUSTMENT_MAX=1000000

ANOMALY_WITHDRAWAL_THRESHOLD_NGN=500000
ANOMALY_WITHDRAWAL_WINDOW_MINUTES=60
ANOMALY_WITHDRAWAL_COUNT=3
ANOMALY_ADMIN_ADJUSTMENT_NGN=500000
ANOMALY_FAILED_LOGIN_THRESHOLD=5
ANOMALY_DEVICE_COUNT=5

# Optional admin seed (use bcrypt hash for password)
ADMIN_SEED_EMAIL=admin@glyvtu.ng
ADMIN_SEED_PASSWORD_HASH=
