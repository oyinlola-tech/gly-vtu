PORT=3000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gly_vtu

# CRITICAL: Authentication & Encryption Secrets
# IMPORTANT: Each secret MUST be:
#   1. Unique (all 4 must be different values)
#   2. Strong (≥32 characters, random alphanumeric + symbols)
#   3. Stored securely (use a secrets manager in production, NOT in code/git)
# DO NOT use default values or short strings in production
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# JWT authentication secret (used to sign access & refresh tokens)
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_32_CHAR_SECRET_IN_PRODUCTION

# JWT admin authentication secret (separate from user JWT for layered security)
JWT_ADMIN_SECRET=CHANGE_THIS_TO_ANOTHER_STRONG_32_CHAR_SECRET_IN_PRODUCTION

# PII (Personally Identifiable Information) encryption secret
# Used to encrypt sensitive user data: names, emails, phones, KYC data
# This MUST be separate from JWT_SECRET for defense in depth
PII_ENCRYPTION_KEY=CHANGE_THIS_TO_ANOTHER_UNIQUE_32_CHAR_SECRET_IN_PRODUCTION

# Cookie encryption secret (for encrypting refresh tokens in cookies)
# This MUST be separate from JWT_SECRET for defense in depth
COOKIE_ENC_SECRET=CHANGE_THIS_TO_ANOTHER_UNIQUE_32_CHAR_SECRET_IN_PRODUCTION

JWT_ACCESS_TTL=15m
JWT_ACCESS_COOKIE_MINUTES=15
JWT_REFRESH_DAYS=14
COOKIE_REFRESH=true
COOKIE_DOMAIN=
AUTH_COOKIE_NAME=auth_token
ADMIN_AUTH_COOKIE_NAME=admin_auth_token

CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=0

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@glyvtu.ng
EMAIL_LOGO_URL=
BRAND_URL=
SUPPORT_URL=
PRIVACY_URL=
TERMS_URL=

OTP_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
PIN_MAX_ATTEMPTS=5
PIN_LOCK_MINUTES=15
LOGIN_LOCK_MAX=5
LOGIN_LOCK_MINUTES=15
LOGIN_LOCK_WINDOW_MINUTES=15
SECURITY_QUESTION_REQUIRE_PIN_CHANGE=true
SECURITY_QUESTION_REQUIRE_DEVICE_VERIFY=true
SECURITY_QUESTION_REQUIRE_PASSWORD_RESET=true
SECURITY_QUESTION_TRANSFER_LIMIT=50000

RATE_LIMIT_GLOBAL_MAX=600
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_ADMIN_AUTH_MAX=20
RATE_LIMIT_OTP_MAX=10
RATE_LIMIT_WEBHOOK_MAX=120
RATE_LIMIT_BILLS_MAX=60
REDIS_URL=
IDEMPOTENCY_KEY_TTL_HOURS=24

# Data Retention & Cleanup Policies
# Controls how long security events, audit logs, and webhook records are kept
# Minimum values recommended for compliance and forensic analysis:
# - SECURITY_EVENT_RETENTION_DAYS: 180 days (6 months) minimum recommended
# - AUDIT_LOG_RETENTION_DAYS: 365 days (1 year) minimum recommended
# - WEBHOOK_EVENT_RETENTION_DAYS: 90 days minimum recommended
# Shorter retention may violate local data protection regulations (GDPR, PCI DSS)
SECURITY_EVENT_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=365
WEBHOOK_EVENT_RETENTION_DAYS=90


CARD_CHECKOUT_URL=
CARD_PROVIDER=external_card

BANKS_CACHE_TTL_MINUTES=1440
BANKS_REFRESH_INTERVAL_MS=21600000
WS_TOKEN_MAX_AGE_MINUTES=10
TOTP_ISSUER=GLY-VTU
TOTP_WINDOW=2

ADMIN_SEED_EMAIL=admin@glyvtu.ng
ADMIN_SEED_PASSWORD=
ADMIN_SEED_PASSWORD_HASH=

VITE_API_URL=http://localhost:3000/app/api
VITE_ADMIN_API_URL=http://localhost:3000/app/admin/api
VITE_WS_URL=ws://localhost:3000/ws
VITE_VIRTUAL_CARD_PROVIDER=Flutterwave
VITE_VIRTUAL_CARD_STATUS=coming_soon

# VTpass (Bills)
VTPASS_BASE_URL=https://sandbox.vtpass.com
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_SECRET_KEY=
VTPASS_ENV=sandbox
VTPASS_WEBHOOK_SECRET=
VTPASS_WEBHOOK_IPS=

# Flutterwave (Virtual Cards)
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_BASE_URL=https://api.flutterwave.com
FLW_WEBHOOK_HASH=

# CRITICAL: Flutterwave Webhook IP Whitelist (Required in Production)
# This validates that webhook events come from Flutterwave infrastructure
# Obtain current IPs from: https://developer.flutterwave.com/docs/webhooks/
# Example: FLW_WEBHOOK_IPS=52.29.183.101,34.218.116.96
# Multiple IPs: comma-separated with no spaces
# Production will FAIL on startup if this is not configured
FLW_WEBHOOK_IPS=

# KYC Provider (IdentityPass / Prembly)
# Set KYC_PROVIDER=identitypass or prembly
# IdentityPass defaults:
#   BASE_URL=https://api.myidentitypay.com
#   BVN_PATH=/api/v2/biometrics/merchant/data/verification/bvn
#   NIN_PATH=/api/v1/biometrics/merchant/data/verification/nin_wo_face
# Prembly defaults:
#   BASE_URL=https://api.prembly.com
#   BVN_PATH=/verification/bvn_validation
#   NIN_PATH=/verification/vnin-basic
KYC_PROVIDER=mock
KYC_PROVIDER_BASE_URL=
KYC_PROVIDER_BVN_PATH=
KYC_PROVIDER_NIN_PATH=
KYC_PROVIDER_TOKEN=
KYC_PROVIDER_APP_ID=
KYC_PROVIDER_API_KEY_HEADER=x-api-key
KYC_PROVIDER_APP_ID_HEADER=app-id

KYC_L1_DAILY_LIMIT=50000
KYC_L1_MONTHLY_LIMIT=200000
KYC_L2_DAILY_LIMIT=500000
KYC_L2_MONTHLY_LIMIT=2000000
KYC_L3_DAILY_LIMIT=5000000
KYC_L3_MONTHLY_LIMIT=20000000

